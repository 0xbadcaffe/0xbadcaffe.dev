---
const { current } = Astro.props;
const links = [
  { href: '/blog', label: 'posts' },
  { href: '/projects', label: 'projects' },
  { href: '/about', label: '$ whoami' },
];
---

<header class="sticky top-0 z-50 border-b border-[var(--border)] bg-[var(--nav-bg)] backdrop-blur-md">
  <div class="mx-auto flex max-w-4xl items-center justify-between gap-4 px-4 py-3">
    <a
      href="/"
      aria-label="0xbadcaffe home"
      class="shrink-0 py-1 text-2xl leading-7 font-semibold whitespace-nowrap text-[var(--foreground)] transition-colors hover:text-[var(--accent)]"
    >
      <span class="text-[var(--accent)]">0x</span>badcaffe
    </a>
    <nav class="flex flex-wrap items-center justify-end gap-x-4 gap-y-1 sm:gap-x-5">
      {links.map(l => (
        <a
          href={l.href}
          class={`font-medium text-[var(--text-dim)] hover:text-[var(--foreground)] transition-colors ${current === l.href ? 'active-nav' : ''}`}
        >
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>
