---
const { current } = Astro.props;
const links = [
  { href: '/blog', label: '/logs' },
  { href: '/projects', label: '/projects' },
  { href: '/#about', label: '/whoami' },
];
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-brand">0x<span>badcaffe</span></a>
    <ul class="nav-links">
      {links.map(l => (
        <li>
          <a href={l.href} class={current === l.href ? 'active' : ''}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="nav-status">
      <span class="status-dot"></span>ONLINE
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 9995;
    border-bottom: 1px solid var(--border);
    background: rgba(3, 5, 8, 0.93);
    backdrop-filter: blur(14px);
  }
  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
  }
  .nav-brand {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--cyan);
    text-shadow: 0 0 12px var(--cyan);
    letter-spacing: 2px;
    text-decoration: none;
    transition: text-shadow 0.3s;
  }
  .nav-brand:hover { text-shadow: 0 0 20px var(--cyan); }
  .nav-brand span { color: var(--amber); text-shadow: 0 0 12px var(--amber); }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    color: var(--text-dim);
    font-size: 0.75rem;
    letter-spacing: 2px;
    transition: color 0.2s, text-shadow 0.2s;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--amber);
    text-shadow: 0 0 8px var(--amber);
  }
  .nav-status {
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  @media (max-width: 600px) {
    .nav-status { display: none; }
    .nav-links { gap: 1rem; }
  }
</style>
