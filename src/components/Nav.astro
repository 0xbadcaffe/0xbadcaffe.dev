---
const { current } = Astro.props;
const links = [
  { href: '/blog', label: 'posts' },
  { href: '/projects', label: 'projects' },
  { href: '/about', label: '$ whoami' },
];
---

<header class="sticky top-0 z-50 bg-[var(--nav-bg)] backdrop-blur-sm border-b border-[var(--border)]">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
    <a href="/" class="text-2xl font-semibold hover:text-[var(--accent)] transition-colors">
      0xbadcaffe
    </a>
    <nav class="flex items-center gap-6">
      {links.map(l => (
        <a
          href={l.href}
          class={`text-[var(--text-dim)] hover:text-[var(--foreground)] transition-colors ${current === l.href ? 'active-nav' : ''}`}
        >
          {l.label}
        </a>
      ))}
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors cursor-pointer"
      >
        <span id="theme-icon">◑</span>
      </button>
    </nav>
  </div>
</header>

