---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="Home" current="/">

  <div class="wrapper page-wrap">

    <!-- INTRO -->
    <section class="intro">
      <div class="intro-row">
        <div class="intro-content">
          <div class="intro-eyebrow">kernel // networking // reverse engineering</div>
          <h1 class="intro-handle">0xbadcaffe</h1>
          <div class="intro-links">
            <a href="https://github.com/0xbadcaffe" target="_blank" rel="noopener">github</a>
            <span class="sep">//</span>
            <a href="/rss.xml">rss</a>
            <span class="sep">//</span>
            <a href="/#about">whoami</a>
          </div>
        </div>

        <div class="intro-hex">
          <div class="hex-display">
            <div>0xDEAD <span class="c">←</span></div>
            <div class="c">0xBADCAFFE ◉</div>
            <div>0xCAFEBABE</div>
            <div>0xDEADBEEF</div>
            <div>0x00000000</div>
          </div>
          <p class="intro-bio">
            for (;;) &#123;<br />
            &nbsp;&nbsp;Break();<br />
            &nbsp;&nbsp;Build();<br />
            &nbsp;&nbsp;DrinkCoffee();<br />
            &#125;
          </p>
        </div>
      </div>
    </section>

    <!-- WRITING -->
    <section class="writing">
      <div class="section-hd">
        <span class="section-lbl">writing</span>
        <div class="section-ln"></div>
      </div>
      <div class="writing-list">
        {posts.map(post => {
          const d = post.data.pubDate;
          const date = d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
          return (
            <a class="entry" href={`/blog/${post.slug}`}>
              <div class="entry-date">{date}</div>
              <div class="entry-body">
                <div class="entry-title">{post.data.title}</div>
                <div class="entry-desc">{post.data.description}</div>
                <div class="entry-tags">
                  {(post.data.tags ?? []).map((t: string) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- TERMINAL -->
    <section class="terminal-section">
      <div class="terminal">
        <div class="terminal-bar">
          <div class="t-dot"></div>
          <div class="t-dot"></div>
          <div class="t-dot"></div>
          <span class="t-title">0xbadcaffe@localhost ~</span>
        </div>
        <div class="terminal-body">
          <div><span class="t-prompt">➜ 0xbadcaffe</span> git log --oneline -4</div>
          <div class="t-output"><span class="t-highlight">a3f1c9b</span> packrat: add libpcap capture backend</div>
          <div class="t-output"><span class="t-highlight">7e2d041</span> packrat: implement Visualize tab with sparklines</div>
          <div class="t-output"><span class="t-highlight">c8b3e12</span> hookeye: fix ptrace attach race condition</div>
          <div class="t-output"><span class="t-highlight">91a4f88</span> hookeye: PLT resolver initial commit</div>
          <br />
          <div><span class="t-prompt">➜ 0xbadcaffe</span> echo $MISSION</div>
          <div class="t-output"><span class="t-success">kernel // packets // bits</span></div>
          <br />
          <div><span class="t-prompt">➜ 0xbadcaffe</span> <span class="t-cursor"></span></div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="about" id="about">
      <div class="section-hd">
        <span class="section-lbl">$ whoami</span>
        <div class="section-ln"></div>
      </div>
      <div class="about-body">
        <p>
          This is a logbook. What I built, what broke, what I learned. No schedule — just notes when something is worth keeping. I hope you had a !(0xbadcaffe).
        </p>
        <div class="skills">
          {[
            'Linux Kernel', 'Rust', 'Packet Analysis',
            'Reverse Engineering', 'FPGA / HDL', 'Yocto / Petalinux',
            'libpcap', 'Embedded C', 'Network Protocols',
          ].map(s => <span class="skill">{s}</span>)}
        </div>
      </div>
    </section>

  </div>

</Base>

<style>
  .page-wrap {
    padding: 5rem 2rem 7rem;
  }

  /* ── INTRO ── */
  .intro {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
    position: relative;
  }
  .intro-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
  }
  .intro-content { flex: 1; min-width: 0; }

  .intro-eyebrow {
    font-size: 0.7rem;
    color: var(--cyan);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }
  .intro-eyebrow::before { content: '> '; color: var(--amber); }
  .intro-handle {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--cyan);
    text-shadow: 0 0 30px rgba(0,212,255,0.4), 0 0 60px rgba(0,212,255,0.15);
    margin-bottom: 1.5rem;
    letter-spacing: 2px;
    line-height: 1.1;
  }
  .intro-bio {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--text-dim);
    line-height: 1.85;
    margin-bottom: 1.8rem;
    max-width: 520px;
  }
  .intro-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .intro-links a { color: var(--text-dim); transition: color 0.2s; }
  .intro-links a:hover { color: var(--amber); }
  .sep { color: var(--border); user-select: none; }

  /* Hex display */
  .intro-hex {
    position: absolute;
    right: 0;
    top: 0;
  }
  .hex-display {
    font-size: 0.7rem;
    color: var(--text-dim);
    line-height: 2;
    letter-spacing: 1px;
    text-align: right;
  }
  .hex-display .c { color: var(--cyan); text-shadow: 0 0 8px var(--cyan); }
  .intro-hex .intro-bio {
    margin-top: 1rem;
    text-align: left;
    font-size: 0.75rem;
  }

  /* ── WRITING ── */
  .writing { margin-bottom: 4rem; }

  .section-hd {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .section-lbl {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--amber);
    letter-spacing: 4px;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .section-ln {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--amber-dim), transparent);
  }

  .writing-list { display: flex; flex-direction: column; }
  .entry {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 1.5rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--border);
    position: relative;
    transition: background 0.2s;
  }
  .entry::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0; bottom: 0;
    width: 2px;
    background: var(--cyan);
    box-shadow: 0 0 8px var(--cyan);
    transform: scaleY(0);
    transition: transform 0.2s;
  }
  .entry:hover::before { transform: scaleY(1); }
  .entry-date {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 1px;
    padding-top: 0.25rem;
    white-space: nowrap;
  }
  .entry-title {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.4rem;
    line-height: 1.4;
    transition: color 0.2s;
  }
  .entry:hover .entry-title { color: var(--cyan); }
  .entry-desc {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 0.6rem;
  }
  .entry-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  /* ── TERMINAL ── */
  .terminal-section { margin-bottom: 4rem; }

  /* ── ABOUT ── */
  .about { max-width: 640px; padding-bottom: 2rem; }
  .about-body p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--text-dim);
    line-height: 1.85;
    margin-bottom: 1.1rem;
  }
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }
  .skill {
    font-size: 0.65rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.25rem 0.65rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.2s, border-color 0.2s;
  }
  .skill:hover { color: var(--cyan); border-color: rgba(0,212,255,0.4); }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .page-wrap { padding: 4.5rem 1.25rem 5rem; }
    .intro-row { flex-direction: column; gap: 1rem; }
    .intro-hex { display: none; }
    .entry { grid-template-columns: 1fr; gap: 0.3rem; }
    .entry-date { padding-top: 0; font-size: 0.68rem; }
    .entry-title { font-size: 1rem; }
    .entry-desc { font-size: 0.85rem; line-height: 1.5; margin-bottom: 0; }
    .entry-tags { display: none; }
    .entry::before { left: -1.25rem; }
    .entry { padding: 1.2rem 0; }
    .terminal-section { display: none; }
  }
</style>
