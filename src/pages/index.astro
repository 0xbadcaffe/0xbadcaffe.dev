---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function readingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
---

<Base title="Home" current="/">
  <section class="pt-10 pb-6">
    <h1 class="text-3xl font-bold mb-1">0xbadcaffe</h1>
    <p class="text-[var(--text-dim)] text-sm uppercase tracking-widest mb-4">kernel // networking // reverse engineering</p>
    <div class="flex items-center gap-2 text-sm">
      <a href="https://github.com/0xbadcaffe" target="_blank" rel="noopener" class="text-[var(--accent)] underline decoration-dashed underline-offset-4 hover:decoration-2">github</a>
      <span class="text-[var(--text-dim)]">/</span>
      <a href="/rss.xml" class="text-[var(--accent)] underline decoration-dashed underline-offset-4 hover:decoration-2">rss</a>
      <span class="text-[var(--text-dim)]">/</span>
      <a href="/#about" class="text-[var(--accent)] underline decoration-dashed underline-offset-4 hover:decoration-2">about</a>
    </div>
  </section>

  <hr class="border-[var(--border)]" />

  <section class="py-8">
    <ul>
      {posts.map(post => {
        const d = post.data.pubDate;
        const date = `${d.getDate()} ${d.toLocaleDateString('en-US', { month: 'short' })}, ${d.getFullYear()}`;
        const mins = readingTime(post.body);
        return (
          <li class="my-8">
            <a href={`/blog/${post.slug}`} class="group inline-block">
              <h3 class="text-lg font-medium text-[var(--accent)] underline decoration-dashed underline-offset-4 decoration-[1px] group-hover:decoration-2 transition-all">
                {post.data.title}
              </h3>
            </a>
            <div class="flex items-center gap-2 mb-2 text-sm italic opacity-70">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <time>{date}</time>
              <span>•</span>
              <span>{mins} min read</span>
            </div>
            <p class="opacity-80 leading-relaxed">{post.data.description}</p>
          </li>
        );
      })}
    </ul>
  </section>

  <hr class="border-[var(--border)]" />

  <section class="py-8 max-w-xl" id="about">
    <h2 class="text-sm uppercase tracking-widest text-[var(--accent)] mb-5">$ whoami</h2>
    <p class="text-[var(--text-dim)] leading-relaxed mb-4">
      This is a logbook. What I built, what broke, what I learned. No schedule — just notes when something is worth keeping. I hope you had a !(0xbadcaffe).
    </p>
    <div class="flex flex-wrap gap-2 mt-4">
      {[
        'Linux Kernel', 'Rust', 'Packet Analysis',
        'Reverse Engineering', 'FPGA / HDL', 'Yocto',
        'libpcap', 'Embedded C', 'Network Protocols',
      ].map(s => (
        <span class="text-xs text-[var(--text-dim)] border border-[var(--border)] px-2 py-0.5 uppercase tracking-wide">{s}</span>
      ))}
    </div>
    <p class="text-xs text-[var(--text-dim)] mt-4">
      Not familiar with hexspeak? <a href="https://en.wikipedia.org/wiki/Hexspeak" target="_blank" rel="noopener" class="text-[var(--accent)] underline decoration-dashed underline-offset-4 hover:decoration-2">Wikipedia has you covered.</a>
    </p>
  </section>
</Base>
