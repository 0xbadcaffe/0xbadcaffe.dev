---
import Base from '../layouts/Base.astro';

const projects = [
  {
    name: 'packrat',
    url: 'https://github.com/0xbadcaffe/packrat',
    description: 'Wireshark-style TUI packet analyzer built in Rust with Ratatui. Five tabs: Packets, Analysis, Strings, Dynamic, Visualize. Optional libpcap capture backend.',
    tags: ['rust', 'ratatui', 'libpcap', 'networking'],
    status: 'active',
    lang: 'Rust',
  },
  {
    name: 'hookeye',
    url: 'https://github.com/0xbadcaffe/hookeye',
    description: 'Dynamic instrumentation tool for tracing function calls and PLT hooks at runtime using ptrace.',
    tags: ['rust', 'ptrace', 'elf', 'reverse-engineering'],
    status: 'active',
    lang: 'Rust',
  },
];
---

<Base title="/projects" current="/projects">
  <section class="pt-10 pb-16">
    <header class="mb-8">
      <h1 class="text-2xl font-bold mb-2">projects</h1>
      <p class="text-sm text-[var(--text-dim)] italic">things i build when the hardware cooperates.</p>
    </header>

    <hr class="border-[var(--border)] mb-8" />

    <div class="space-y-4">
      {projects.map(p => (
        <a
          href={p.url}
          target="_blank"
          rel="noopener"
          class="block border border-[var(--border)] p-6 hover:border-[var(--accent)] transition-colors group"
        >
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-baseline gap-1">
              <span class="text-sm text-[var(--text-dim)]">~/</span>
              <span class="font-bold text-[var(--accent)] tracking-wide group-hover:underline decoration-dashed underline-offset-4">{p.name}</span>
            </div>
            <div class="flex items-center gap-1.5 text-xs uppercase tracking-widest text-emerald-400">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block" style="animation: pulse 2s infinite" />
              {p.status}
            </div>
          </div>
          <p class="text-sm text-[var(--text-dim)] leading-relaxed mb-4">{p.description}</p>
          <div class="flex items-center justify-between flex-wrap gap-2">
            <div class="flex gap-2 flex-wrap">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            <span class="text-xs text-[var(--accent)] border border-[var(--border)] px-2 py-0.5 uppercase tracking-wide">{p.lang}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
