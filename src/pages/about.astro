---
import Base from '../layouts/Base.astro';
---

<Base title="About" current="/about">
  <article class="mx-auto w-full max-w-3xl px-4 pt-10 pb-16">

    <h1 class="text-2xl font-bold text-[var(--accent)] mb-2">About</h1>
    <hr class="border-[var(--border)] mb-8" />

    <p class="text-[var(--foreground)] leading-relaxed mb-8">
      This blog is a logbook. What I built, what broke, what I learned. No schedule — just notes when something is worth keeping.
    </p>

    <div class="flex flex-wrap gap-3 mb-8">
      <a href="https://github.com/0xbadcaffe" target="_blank" rel="noopener" class="px-4 py-2 border border-[var(--border)] text-[var(--text-dim)] hover:text-[var(--accent)] hover:border-[var(--accent)] transition-colors text-sm">github</a>
      <a href="https://x.com/0xbadcaffe" target="_blank" rel="noopener" class="px-4 py-2 border border-[var(--border)] text-[var(--text-dim)] hover:text-[var(--accent)] hover:border-[var(--accent)] transition-colors text-sm">x</a>
      <a href="/rss.xml" class="px-4 py-2 border border-[var(--border)] text-[var(--text-dim)] hover:text-[var(--accent)] hover:border-[var(--accent)] transition-colors text-sm">rss</a>
    </div>

    <p class="text-sm text-[var(--text-dim)]">
      The name is <a href="https://en.wikipedia.org/wiki/Hexspeak" target="_blank" rel="noopener" class="text-[var(--accent)] underline decoration-dashed underline-offset-4 hover:decoration-2">hexspeak</a> — <code class="text-[var(--accent)]">0xBADCAFFE</code>, bad coffee. Accurate.
    </p>
  </article>
</Base>
