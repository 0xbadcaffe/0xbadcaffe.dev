---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const byYear: Record<string, typeof posts> = {};
for (const post of posts) {
  const year = post.data.pubDate.getFullYear().toString();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(post);
}
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<Base title="posts" current="/blog">
  <div class="wrapper page-wrap">

    <header class="page-header">
      <h1 class="page-title">posts</h1>
      <p class="page-sub">kernel internals, packet analysis, reverse engineering, embedded systems.</p>
    </header>

    <hr class="divider" />

    {years.map(year => (
      <section class="year-group">
        <h2 class="year-label">{year}</h2>
        <ul class="posts-list">
          {byYear[year].map(post => {
            const date = post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            return (
              <li class="post-item">
                <a href={`/blog/${post.slug}`} class="post-link">
                  <span class="post-date">{date}</span>
                  <span class="post-title">{post.data.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}

  </div>
</Base>

<style>
  .page-wrap { padding: 3rem 0 6rem; }
  .page-header { padding-bottom: 1.5rem; }
  .page-title {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .page-sub {
    font-size: 0.9rem;
    color: var(--text-dim);
    font-style: italic;
  }
  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 2rem;
  }
  .year-group { margin-bottom: 2.5rem; }
  .year-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .posts-list { list-style: none; }
  .post-item { border-bottom: 1px solid var(--border); }
  .post-item:last-child { border-bottom: none; }
  .post-link {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.85rem 0;
    transition: color 0.2s;
  }
  .post-date {
    font-size: 0.8rem;
    color: var(--text-dim);
    font-style: italic;
    white-space: nowrap;
    min-width: 60px;
  }
  .post-title {
    font-size: 1rem;
    color: var(--accent);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    transition: text-decoration-thickness 0.15s;
  }
  .post-link:hover .post-title { text-decoration-thickness: 2px; }

  @media (max-width: 640px) {
    .post-link { flex-direction: column; gap: 0.2rem; }
    .post-date { font-size: 0.75rem; }
  }
</style>
